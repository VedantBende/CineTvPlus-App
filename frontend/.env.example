# ============================================================
# 🎬 CineTv+ Environment Configuration
# ============================================================
# This project includes both frontend and backend components.
#
# ⚠️ Video Playback Notice:
# The video playback-related variables below are non-functional.
# The actual streaming/embedding APIs are not included due to
# legal and compliance reasons.
#
# This project does NOT host or distribute any video content.
# This setup is intended only for UI/UX demonstration and
# project exploration purposes.
# ============================================================

VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
VITE_API_URL=/api

# TMDB Configuration (used for movie/TV metadata)
VITE_TMDB_API_KEY=your_tmdb_api_key
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
VITE_TMDB_BACKDROP_BASE_URL=https://image.tmdb.org/t/p/original

# Video Playback (intentionally non-functional)
VITE_VIDEO_EMBED_URL=disabled
VITE_PLAYER_BASE_URL=disabled