# ============================================================
# 🎬 CineTv+ Environment Configuration
# ============================================================
# This project includes both frontend and backend components.
#
# ⚠️ Video Playback Notice:
# The video playback-related variables below are non-functional.
# The actual streaming/embedding APIs are not included due to
# legal and compliance reasons.
#
# This project does NOT host or distribute any video content.
# This setup is intended only for UI/UX demonstration and
# project exploration purposes.
# ============================================================

VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
VITE_API_URL=/api

# TMDB Configuration (used for movie/TV metadata)
VITE_TMDB_API_KEY=your_tmdb_api_key
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
VITE_TMDB_BACKDROP_BASE_URL=https://image.tmdb.org/t/p/original
VITE_TMDB_CAST_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w185

# Video Playback (intentionally non-functional)
# Player Alpha
VITE_PLAYER_ALPHA_MOVIE=disabled
VITE_PLAYER_ALPHA_TV=disabled

# Player Beta
VITE_PLAYER_BETA_MOVIE=disabled
VITE_PLAYER_BETA_TV=disabled

# Player Gamma
VITE_PLAYER_GAMMA_MOVIE=disabled
VITE_PLAYER_GAMMA_TV=disabled

# Player Gamma origin
VITE_PLAYER_GAMMA_ORIGIN=disabled

# Player Delta
VITE_PLAYER_DELTA_MOVIE=disabled
VITE_PLAYER_DELTA_TV=disabled

# Player Epsilon
VITE_PLAYER_EPSILON_MOVIE=disabled
VITE_PLAYER_EPSILON_TV=disabled

# Delta + Epsilon shared origin
VITE_PLAYER_DELTA_EPSILON_ORIGIN=disabled

# Player Zeta
VITE_PLAYER_ZETA_MOVIE=disabled
VITE_PLAYER_ZETA_TV=disabled

# Player Eta
VITE_PLAYER_ETA_MOVIE=disabled
VITE_PLAYER_ETA_TV=disabled

# Transition Videos
VITE_TRANSITION_VIDEO_DESKTOP_TO_ANIME=your_link
VITE_TRANSITION_VIDEO_DESKTOP_TO_STANDARD=your_link
VITE_TRANSITION_VIDEO_MOBILE_TO_ANIME=your_link
VITE_TRANSITION_VIDEO_MOBILE_TO_STANDARD=your_link

# Otaku Link
VITE_OTAKU_LIST_URL=your_link